# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code temp files
tmpclaude-*

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
_tmp_*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
build_*.txt
error.txt
check.ts
check-output.txt

# env files (NEVER commit real credentials)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.sentry-build-plugin

# lock files (pnpm project - ignore npm/yarn locks)
package-lock.json
yarn.lock

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/
.idea/
*.swp
*.swo

# test scripts with credentials
test-mp.js
test-env.js
