# =================================
# SUPABASE CREDENTIALS
# =================================
# Project: laaldea-prod
# Region: South America (São Paulo)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Public URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key (safe to use in frontend with RLS enabled)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ SERVICE ROLE KEY (SECRET - NEVER EXPOSE IN FRONTEND)
# This key bypasses Row Level Security - use ONLY in API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =================================
# MERCADOPAGO
# =================================
# Get these from: https://www.mercadopago.com.uy/developers/panel/app
# Use TEST credentials for development/sandbox

# Public Key (frontend - safe to expose)
MP_PUBLIC_KEY=APP_USR-your-public-key-here

# Access Token (backend - NEVER expose in frontend)
MP_ACCESS_TOKEN=APP_USR-your-access-token-here

# Webhook Secret (for signature verification - get from MP dashboard)
# Go to: https://www.mercadopago.com.uy/developers → Webhooks
# This is used to verify webhook authenticity in production
MP_WEBHOOK_SECRET=your-webhook-secret-here

# =================================
# APP CONFIG
# =================================
NEXT_PUBLIC_URL=http://localhost:3000
APP_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_WHATSAPP_PHONE=your-whatsapp-phone-here
NEXT_PUBLIC_BANK_NAME=your-bank-name
NEXT_PUBLIC_BANK_ACCOUNT_UYU=your-bank-account-uyu
NEXT_PUBLIC_BANK_ACCOUNT_USD=your-bank-account-usd
NEXT_PUBLIC_BANK_HOLDER=your-bank-account-holder
NEXT_PUBLIC_BANK_RUT=your-bank-rut

# =================================
# ANALYTICS
# =================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# =================================
# IMAGE OPTIMIZATION MODE
# =================================
# Keep true while Vercel image optimization quota is exhausted.
# Set to false to re-enable Next.js/Vercel optimization after reset.
NEXT_IMAGE_UNOPTIMIZED=true

# =================================
# EMAIL (Brevo)
# =================================
# Get API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key
FROM_EMAIL=your-email@gmail.com
FROM_NAME=La Aldea
ADMIN_EMAIL=your-email@gmail.com
# Get from Google Business Profile: https://business.google.com
# Go to your profile > Get more reviews > copy the share link
# Leave empty to hide the review CTA in emails
GOOGLE_REVIEW_URL=https://your-google-review-url.example

# =================================
# ADMIN PANEL AUTHENTICATION (Clerk)
# =================================
# Get these from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# =================================
# SENTRY (Error Monitoring)
# =================================
SENTRY_DSN=https://your-dsn@xxx.ingest.us.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@xxx.ingest.us.sentry.io/xxxxx

# =================================
# HUBSPOT (for leads, optional MVP)
# =================================
# HUBSPOT_API_KEY=pat-xxx

# =================================
# INNGEST (Event-Driven Background Jobs)
# =================================
# Get these from: https://app.inngest.com → Manage → Keys
# Event Key: used to send events from your app
INNGEST_EVENT_KEY=your-event-key-here
# Signing Key: used to verify Inngest requests to /api/inngest
INNGEST_SIGNING_KEY=your-signing-key-here